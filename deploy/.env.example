# deploy/.env.example — copy to deploy/.env for local development (gitignored)
# Never commit .env with real values

# PostgreSQL
POSTGRES_USER=aisat
POSTGRES_PASSWORD=change-me-local

# MinIO (S3-compatible)
MINIO_ROOT_USER=change-me-local
MINIO_ROOT_PASSWORD=change-me-local

# Casdoor (update with real values from Casdoor admin after first run)
# See: https://casdoor.org/docs/basic/server-installation
CASDOOR_CLIENT_ID=
CASDOOR_CLIENT_SECRET=
CASDOOR_ENDPOINT=http://localhost:8088

# App secrets (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-local-jwt-secret
OPENAI_API_KEY=
COHERE_API_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
S3_BUCKET=aisat-dev
S3_REGION=us-east-1
