# track-env — hook preset for the single-branch-development bundle.
#
# TWO LAYERS (both optional, both live in .github/hooks/ next to the scripts):
#   * track-env.base.sh  — COMMITTED, repo-wide defaults shared across every
#     track/worktree. Copy THIS file to .github/hooks/track-env.base.sh, fill in
#     the values common to your repo, and commit it. Because it is committed it
#     travels into every worktree automatically (single-branch AND parallel
#     tracks) — nothing is copied at run start.
#   * track-env.sh       — GITIGNORED, per-worktree LOCAL override. Optional.
#     Copy this file to .github/hooks/track-env.sh in a worktree only when that
#     branch must deviate from the repo base (e.g. a narrower writable scope).
#
# WHY EITHER EXISTS
#   The track-*.sh hooks read all their config from the environment, and each
#   no-ops until its var is set. Hand-exporting a dozen TRACK_* vars every run is
#   the #1 footgun: a resume that forgets them runs SILENTLY UNGATED (guard off,
#   evidence gate trivially passes). Binding the config to a file the hooks
#   auto-source removes that footgun.
#
# PRECEDENCE (most specific wins; every line uses `${VAR:-default}`)
#   exported env  >  track-env.sh (worktree)  >  track-env.base.sh (repo)  >  script default
#   Each hook sources local first, then base, so a worktree value wins over the
#   repo base, and an already-exported value (e.g. an executing-parallel-tracks
#   per-track override) wins over both — no file edit needed. To make a value
#   authoritative, drop the `${VAR:-...}` wrapper and assign it directly.
#
# NOTE: RUN_ID is intentionally NOT preset here — it is MINTED per run by
# track-preflight.sh and recovered from the runs/*.dispatch breadcrumb on resume.
# Hand-setting it breaks resume. Leave it to the preflight step.

# --- guard: this branch's writable scope + frozen entrypoints ----------------
export TRACK_ALLOWED_PREFIXES="${TRACK_ALLOWED_PREFIXES:-src:test}"   # colon-separated path prefixes this branch may edit
export TRACK_FROZEN_PATHS="${TRACK_FROZEN_PATHS:-}"                   # colon-separated exact files no branch may edit (leave empty on bootstrap)
export TRACK_IMMUTABLE_PREFIXES="${TRACK_IMMUTABLE_PREFIXES:-migrations/}"  # committed files here are append-only
export TRACK_GUARD_DESTRUCTIVE="${TRACK_GUARD_DESTRUCTIVE:-1}"        # deny DROP/TRUNCATE/FLUSHALL/rm -rf etc. (unset to waive)
export TRACK_ALLOW_FF_PUSH="${TRACK_ALLOW_FF_PUSH:-}"                 # set to 1 ONLY for a PR-rework flow; default lockout stops the worker at the draft PR

# --- run state ---------------------------------------------------------------
export RUNS_DIR="${RUNS_DIR:-runs}"                                   # run record + breadcrumb dir — MUST be gitignored (see hooks.md)

# --- preflight ---------------------------------------------------------------
export PREFLIGHT_REQUIRE_GH="${PREFLIGHT_REQUIRE_GH:-1}"              # require authenticated gh (0 to waive on early setup runs)
export PREFLIGHT_REQUIRE_TOOLCHAIN="${PREFLIGHT_REQUIRE_TOOLCHAIN:-}" # comma-separated bins that must be on PATH, e.g. "go,uv"

# --- evidence gate -----------------------------------------------------------
# Use EITHER TRACK_TEST_CMD_PATTERN (simple: one "test" kind) OR the KINDS/RULES
# pair below (multi-kind), not both. Labels in KINDS MUST match the kinds named
# in RULES / REQUIRED_EVIDENCE — preflight warns on any mismatch.
export TRACK_EVIDENCE_KINDS="${TRACK_EVIDENCE_KINDS:-go-test:go test -race;py:uv run pytest;ts:tsc --noEmit}"
export TRACK_EVIDENCE_RULES="${TRACK_EVIDENCE_RULES:-*.go:go-test;*.py:py;*.tsx:ts;*.ts:ts;migrations/*:pg-explain}"
export TRACK_REQUIRED_EVIDENCE="${TRACK_REQUIRED_EVIDENCE:-}"        # kinds required on EVERY diff (floor); empty = rules-only
export TRACK_BASE_REF="${TRACK_BASE_REF:-origin/main}"               # STRONGLY RECOMMENDED — the gate needs a real base or a committed diff looks empty and passes silently

# --- ceilings / hardening ----------------------------------------------------
export TRACK_MAX_TOOL_CALLS="${TRACK_MAX_TOOL_CALLS:-200}"           # tool-call hard stop
export TRACK_SENTINEL="${TRACK_SENTINEL:-1}"                         # Stop: scan staged diff for secrets/leftovers (unset to disable)

# --- notify (optional) -------------------------------------------------------
export TRACK_NOTIFY_WEBHOOK="${TRACK_NOTIFY_WEBHOOK:-}"              # Slack/Discord/generic webhook for terminal state; empty = no notify
